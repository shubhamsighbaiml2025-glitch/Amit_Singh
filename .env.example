# ------------------------------------------------------------
# Firebase Web App Config
# Firebase Console -> Project settings -> General -> Your apps
# ------------------------------------------------------------
VITE_FIREBASE_API_KEY=PASTE_FIREBASE_WEB_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=PASTE_SENDER_ID
VITE_FIREBASE_APP_ID=PASTE_APP_ID

# ------------------------------------------------------------
# Cloudinary Upload Config
# Cloudinary Dashboard -> Settings -> Upload -> Upload presets
# Use an unsigned upload preset.
# ------------------------------------------------------------
VITE_CLOUDINARY_CLOUD_NAME=PASTE_CLOUDINARY_CLOUD_NAME
VITE_CLOUDINARY_UPLOAD_PRESET=PASTE_UNSIGNED_UPLOAD_PRESET
CLOUDINARY_CLOUD_NAME=PASTE_CLOUDINARY_CLOUD_NAME
CLOUDINARY_UPLOAD_PRESET=PASTE_UNSIGNED_UPLOAD_PRESET

# ------------------------------------------------------------
# Optional Firebase Admin Service Account
# Only needed if using backend Firebase Admin APIs.
# If service account key creation is blocked, use Firestore rules instead.
# Never commit real service account JSON.
# ------------------------------------------------------------
FIREBASE_SERVICE_ACCOUNT_JSON=''

# Alternative to FIREBASE_SERVICE_ACCOUNT_JSON:
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nPASTE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ------------------------------------------------------------
# SMTP / Gmail Email Config
# Gmail requires an App Password, not your normal password.
# ------------------------------------------------------------
SMTP_API_PORT=4174
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_TO_EMAIL=receiver@example.com

